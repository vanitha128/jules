# Application Configuration
SERVER_PORT=8080
JWT_SECRET=averysecurejwtsecret!@#shouldBeLongAndRandom

# --- For Go Application (when running inside Docker via docker-compose) ---
# These are used by pkg/config/config.go to connect to DB and Redis services.

# PostgreSQL DSN for the Go application
# The hostname 'db' refers to the service name in docker-compose.yml
# The user, password, and dbname should match the POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB for the 'db' service.
POSTGRES_DSN=postgresql://user:password@db:5432/go_moon_db?sslmode=disable&TimeZone=UTC

# Redis Address for the Go application
# The hostname 'redis' refers to the service name in docker-compose.yml
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0


# --- For Docker Compose Services (credentials for the DB and Redis services themselves) ---
# These are used by the 'db' and 'redis' services in docker-compose.yml.
# For simplicity in local development, these often match the app's view of them.

# PostgreSQL Service Configuration
DB_USER=user
DB_PASSWORD=password
DB_NAME=go_moon_db

# Redis Service Configuration (Redis itself doesn't use user/pass by default for the service)
# If your Redis image is configured to require a password, set it here and in REDIS_PASSWORD above.
# REDIS_SERVICE_PASSWORD=yourredispassword
